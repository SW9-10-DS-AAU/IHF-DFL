      "preLaunchTask": "compile-contracts"
    },
    {
      "name": "Compile - Debug: Experiments",
      "type": "debugpy",
      "request": "launch",
      "program": "experiment/experiments.py",
      "args": [
        "--skipFolder",
        "experiment/data",
        "--author",
        "Nykjaer"
      ],
      "console": "integratedTerminal",
      "preLaunchTask": "compile-contracts"
    },
    {
      "name": "Debug: Experiments",
      "type": "debugpy",
      "request": "launch",
      "program": "experiment/experiments.py",
      "args": [
        "--skipFolder",
        "experiment/data"
      ],
      "console": "integratedTerminal",
    },
    {
      "name": "Python Debugger: Processor",
      "type": "debugpy",
      "request": "launch",
      "program": "scripts/processData.py",
      "console": "integratedTerminal"
    },
    {
      "name": "Python Debugger: Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal"
    }
